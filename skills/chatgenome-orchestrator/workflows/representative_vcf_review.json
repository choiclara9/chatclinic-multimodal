{
  "name": "representative_vcf_review",
  "description": "Run the default representative VCF interpretation workflow on the active VCF source.",
  "source_type": "vcf",
  "requested_view": "summary",
  "studio": {
    "renderer": "candidates"
  },
  "response_kind": "analysis_chat",
  "answer_template": "The {workflow_name} workflow was rerun on the active source.\n\n- Workflow: `{workflow_name}`\n- Active file: `{active_file}`\n- Logged tools: {logged_tools}\n- Candidate variants: {candidate_count}\n\nThe active VCF analysis state has been refreshed. Open Studio cards or ask follow-up questions. Use `$studio ...` if you want the answer grounded in the current VCF review state.",
  "requires": [
    "source_vcf_path"
  ],
  "produces": [
    "analysis",
    "grounded_summary",
    "candidate_variants"
  ],
  "steps": [
    {
      "tool": "vcf_qc_tool",
      "bind": "facts"
    },
    {
      "tool": "annotation_tool",
      "needs": [
        "facts"
      ],
      "bind": "annotations"
    },
    {
      "tool": "snpeff_execution_tool",
      "needs": [
        "facts"
      ],
      "bind": "snpeff_result",
      "on_fail": "continue"
    },
    {
      "tool": "roh_analysis_tool",
      "bind": "roh_segments"
    },
    {
      "tool": "cadd_lookup_tool",
      "needs": [
        "facts",
        "annotations",
        "roh_segments"
      ],
      "bind": "annotations",
      "on_fail": "continue"
    },
    {
      "tool": "revel_lookup_tool",
      "needs": [
        "facts",
        "annotations",
        "roh_segments"
      ],
      "bind": "annotations",
      "on_fail": "continue"
    },
    {
      "tool": "candidate_ranking_tool",
      "needs": [
        "annotations",
        "roh_segments"
      ],
      "bind": "candidate_variants"
    },
    {
      "tool": "clinvar_review_tool",
      "needs": [
        "annotations"
      ],
      "bind": "clinvar_summary"
    },
    {
      "tool": "vep_consequence_tool",
      "needs": [
        "annotations"
      ],
      "bind": "consequence_summary"
    },
    {
      "tool": "clinical_coverage_tool",
      "needs": [
        "annotations"
      ],
      "bind": "clinical_coverage_summary"
    },
    {
      "tool": "filtering_view_tool",
      "needs": [
        "annotations"
      ],
      "bind": "filtering_summary"
    },
    {
      "tool": "symbolic_alt_tool",
      "needs": [
        "annotations"
      ],
      "bind": "symbolic_alt_summary"
    },
    {
      "tool": "grounded_summary_tool",
      "needs": [
        "facts",
        "annotations"
      ],
      "bind": "draft_answer"
    }
  ],
  "default_view": "summary",
  "notes": [
    "This workflow is intended to replace the current hard-coded VCF upload pipeline.",
    "The active VCF source should already be registered before this workflow runs."
  ]
}
