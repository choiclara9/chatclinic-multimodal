{
  "name": "ldblockshow_execution_tool",
  "entrypoint": "plugins.ldblockshow_execution_tool.logic:execute",
  "description": "Run local LDBlockShow on a VCF locus and generate LD heatmap artifacts such as SVG and block tables.",
  "task": "ld-heatmap-visualization",
  "modality": "genomics",
  "approval_required": false,
  "source": "local",
  "routing": {
    "trigger_keywords": ["ldblockshow", "ld block", "ld heatmap", "ld block review"],
    "execution_intents": ["run", "execute", "plot", "generate", "draw", "실행", "돌려", "그려", "생성"],
    "requires_source_vcf": true,
    "question_argument": "region",
    "result_slot": "ldblockshow_result",
    "execution_mode": "direct_endpoint"
  },
  "orchestration": {
    "tool_kind": "visualization",
    "default_stage": "post-annotation",
    "depends_on": ["annotation_tool"],
    "consumes": ["vcf_path", "region"],
    "produces": ["ldblockshow_result"],
    "priority": 70,
    "on_demand": true
  },
  "runtime": {
    "host_compatible": ["cpu"],
    "requires_gpu": false,
    "allow_cpu_fallback": true,
    "estimated_runtime_sec": 6
  },
  "direct_chat": {
    "source_type": "vcf",
    "endpoint": "ldblockshow",
    "argument_mode": "region_or_key_value",
    "requested_view": "ldblockshow",
    "studio": {
      "renderer": "ldblockshow"
    },
    "result_kind": "ldblockshow_result"
  },
  "help": {
    "summary": "Run LDBlockShow on the active VCF source for a requested locus and generate LD heatmap artifacts.",
    "modes": [
      {
        "name": "run",
        "description": "Generate the curated LD block visualization for a specific genomic region."
      }
    ],
    "options": [
      {
        "name": "region",
        "type": "string",
        "required": true,
        "description": "Genomic region in chr:start:end format."
      }
    ],
    "examples": [
      "@ldblockshow chr11:24100000:24200000",
      "@ldblockshow help"
    ],
    "notes": [
      "Uses the active VCF source by default.",
      "A concrete region is required for execution."
    ]
  }
}
