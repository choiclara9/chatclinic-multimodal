{
  "name": "snpeff_execution_tool",
  "entrypoint": "plugins.snpeff_execution_tool.logic:execute",
  "description": "Run local SnpEff annotation on a VCF using the installed Java runtime and local SnpEff genome databases.",
  "task": "variant-annotation-execution",
  "modality": "genomics",
  "approval_required": false,
  "source": "local",
  "routing": {
    "trigger_keywords": ["snpeff", "snp eff"],
    "execution_intents": ["run", "execute", "annotate", "use", "실행", "돌려", "주석", "사용"],
    "requires_source_vcf": true,
    "question_argument": "none",
    "result_slot": "snpeff_result",
    "execution_mode": "direct_endpoint"
  },
  "orchestration": {
    "tool_kind": "execution",
    "default_stage": "post-annotation",
    "depends_on": ["annotation_tool"],
    "consumes": ["vcf_path"],
    "produces": ["snpeff_result"],
    "priority": 80,
    "on_demand": true
  },
  "runtime": {
    "host_compatible": ["cpu"],
    "requires_gpu": false,
    "allow_cpu_fallback": true,
    "estimated_runtime_sec": 8
  },
  "direct_chat": {
    "source_type": "vcf",
    "endpoint": "snpeff",
    "argument_mode": "key_value",
    "requested_view": "snpeff",
    "studio": {
      "renderer": "snpeff"
    },
    "result_kind": "snpeff_result"
  },
  "workflow_binding": {
    "source_type": "vcf",
    "input_map": {
      "vcf_path": "$source_vcf_path",
      "genome_build_guess": "$facts.genome_build_guess"
    },
    "preprocess": "vcf_prepare_snpeff_payload",
    "transform": "snpeff_response",
    "used_tools_label": "snpeff_execution_tool"
  },
  "help": {
    "summary": "Run local SnpEff effect annotation on the active VCF source and preview annotated ANN records.",
    "modes": [
      {
        "name": "run",
        "description": "Run the curated SnpEff annotation workflow for the current VCF."
      }
    ],
    "options": [
      {
        "name": "genome",
        "type": "string",
        "required": false,
        "description": "Optional SnpEff genome database key. ChatGenome usually derives this from the VCF build guess."
      },
      {
        "name": "output_prefix",
        "type": "string",
        "required": false,
        "description": "Optional prefix for generated SnpEff artifacts."
      }
    ],
    "examples": [
      "@snpeff",
      "@snpeff help"
    ],
    "notes": [
      "Uses the active VCF source by default.",
      "Intended as an on-demand annotation preview rather than a general natural-language trigger."
    ]
  }
}
